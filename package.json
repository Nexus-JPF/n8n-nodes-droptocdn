{
  "name": "n8n-nodes-droptocdn",
  "version": "0.1.2",
  "description": "Upload files to Drop to CDN and get instant public CDN URLs",
  "license": "MIT",
  "homepage": "https://droptocdn.com",
  "keywords": [
    "n8n-community-node-package",
    "droptocdn",
    "cdn",
    "file-upload"
  ],
  "author": {
    "name": "Drop to CDN",
    "email": "support@droptocdn.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nexus-JPF/n8n-nodes-droptocdn.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "mkdir -p dist/nodes/DropToCdn && cp nodes/DropToCdn/*.svg nodes/DropToCdn/*.json dist/nodes/DropToCdn/",
    "lint": "eslint credentials nodes",
    "lint:fix": "eslint credentials nodes --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/credentials",
    "dist/nodes",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/DropToCdnApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DropToCdn/DropToCdn.node.js"
    ]
  },
  "dependencies": {
    "form-data": "^4.0.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "n8n-workflow": "^1.82.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.35.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
